.conv-item {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
}

.conv-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.conv-content {
  flex: 1;
}

.conv-name {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.conv-msg {
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.conv-right {
  text-align: right;
}

.conv-time {
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.unread-badge {
  display: inline-block;
  background: #ed6a0c;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: #999;
}
