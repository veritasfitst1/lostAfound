.detail-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.swiper {
  height: 400rpx;
  background: #f0f0f0;
}

.swiper image {
  width: 100%;
  height: 100%;
}

.detail-body {
  padding: 32rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.detail-meta {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.tag {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.tag.lost { background: #fff3f0; color: #ed6a0c; }
.tag.found { background: #e6f7ff; color: #1989fa; }

.detail-desc {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.detail-time, .detail-contact {
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.publisher {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.pub-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.btn-contact {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 32rpx;
}

.comment-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.comment-input-bar {
  margin-bottom: 24rpx;
}

.comment-input {
  flex: 1;
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.btn-comment {
  margin-left: 16rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 16rpx;
}

.comment-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.comment-name {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.comment-text {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}
