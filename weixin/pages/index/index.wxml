<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索物品、地点、描述" value="{{keyword}}" bindconfirm="onSearch" bindinput="onKeywordInput"/>
  </view>
  <view class="filter-bar flex-between">
    <view class="filter-item {{!type && type !== 0 ? 'active' : ''}}" bindtap="onFilterType" data-type="">全部</view>
    <view class="filter-item {{type === 0 ? 'active' : ''}}" bindtap="onFilterType" data-type="0">失物</view>
    <view class="filter-item {{type === 1 ? 'active' : ''}}" bindtap="onFilterType" data-type="1">招领</view>
    <view class="filter-item" bindtap="toggleFilter">分类{{categoryId ? '✓' : ''}}</view>
  </view>
  <view class="filter-cats" wx:if="{{showFilter}}">
    <view class="cat-item {{!categoryId ? 'active' : ''}}" bindtap="onFilterCategory" data-id="">全部分类</view>
    <view class="cat-item {{categoryId === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" data-id="{{item.id}}" bindtap="onFilterCategory">{{item.name}}</view>
  </view>

  <scroll-view scroll-y class="item-list" bindscrolltolower="onReachBottom">
    <view class="item-card" wx:for="{{items}}" wx:key="id" data-id="{{item.id}}" bindtap="toDetail">
      <image class="item-img" src="{{item.images && item.images[0] ? item.images[0] : '/assets/icons/home.png'}}" mode="aspectFill"/>
      <view class="item-info">
        <view class="item-title">{{item.title}}</view>
        <view class="item-meta text-muted">{{item.categoryName}} · {{item.location || '未知'}}</view>
        <view class="item-time text-gray">{{item.eventTime || item.createdAt}}</view>
        <view class="item-tag {{item.type === 0 ? 'lost' : 'found'}}">{{item.type === 0 ? '失物' : '招领'}}</view>
      </view>
    </view>
    <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
    <view class="loading-tip text-gray" wx:elif="{{!hasMore && items.length > 0}}">没有更多了</view>
    <view class="empty-tip" wx:elif="{{!loading && items.length === 0}}">暂无数据</view>
  </scroll-view>
</view>
