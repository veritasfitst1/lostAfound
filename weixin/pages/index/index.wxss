.search-bar {
  padding: 16rpx 0;
}

.search-input {
  background: #fff;
  border-radius: 32rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
}

.filter-bar {
  padding: 16rpx 0;
  font-size: 26rpx;
}

.filter-item {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  background: #fff;
}

.filter-item.active {
  background: #1989fa;
  color: #fff;
}

.filter-cats {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-bottom: 16rpx;
}

.cat-item {
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.cat-item.active {
  background: #1989fa;
  color: #fff;
}

.item-list {
  height: calc(100vh - 280rpx);
}

.item-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.item-img {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  padding: 24rpx;
  position: relative;
}

.item-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.item-meta {
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.item-time {
  font-size: 22rpx;
}

.item-tag {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.item-tag.lost {
  background: #fff3f0;
  color: #ed6a0c;
}

.item-tag.found {
  background: #e6f7ff;
  color: #1989fa;
}

.loading-tip, .empty-tip {
  text-align: center;
  padding: 48rpx;
  font-size: 26rpx;
}
