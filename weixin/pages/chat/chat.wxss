.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.msg-list {
  flex: 1;
  padding: 24rpx;
}

.msg-item {
  display: flex;
  margin-bottom: 24rpx;
}

.msg-item.right {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.msg-item.left .msg-avatar { margin-right: 16rpx; }
.msg-item.right .msg-avatar { margin-left: 16rpx; }

.msg-bubble {
  max-width: 60%;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.msg-item.left .msg-bubble {
  background: #f0f0f0;
}

.msg-item.right .msg-bubble {
  background: #1989fa;
  color: #fff;
}

.input-bar {
  padding: 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input {
  flex: 1;
  padding: 20rpx 24rpx;
  background: #f5f6fa;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.btn-send {
  margin-left: 16rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 32rpx;
}
