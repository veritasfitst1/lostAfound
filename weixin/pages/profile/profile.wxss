.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1989fa 0%, #5cadff 100%);
  border-radius: 24rpx;
  padding: 48rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 32rpx;
  background: #fff;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.menu-section {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.menu-item {
  padding: 32rpx 32rpx;
  font-size: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.arrow {
  color: #999;
  font-size: 36rpx;
}

.logout-btn {
  text-align: center;
  color: #ed6a0c;
  font-size: 30rpx;
  padding: 32rpx;
}
